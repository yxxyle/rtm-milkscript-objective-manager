const formatDate = (date) => date ? `${date.getFullYear()}-${(date.getMonth() + 1).toString().padStart(2, '0')}-${date.getDate().toString().padStart(2, '0')}` : 'N/A';

const formatDateTime = (date) => date ? `${formatDate(date)} ${date.getHours().toString().padStart(2, '0')}:${date.getMinutes().toString().padStart(2, '0')}:${date.getSeconds().toString().padStart(2, '0')}` : 'N/A';

const now = new Date();
const jan_01_1970 = new Date(0);

const weekdays = {
    zh: ['星期日', '星期一', '星期二', '星期三', '星期四', '星期五', '星期六'],
    en: ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday']
};

const formatDateWithWeekday = (date, lang = 'zh') => {
    if (!date || isNaN(date.getTime?.() ?? new Date(date).getTime())) return 'N/A';
    const weekday = weekdays[lang]?.[date.getDay()] ?? '星期日';
    return `${formatDate(date)} ${weekday}`;
};

const formatDateTimeWithWeekday = (date, lang = 'zh') => {
    if (!date || isNaN(date.getTime?.() ?? new Date(date).getTime())) return 'N/A';
    const weekday = weekdays[lang]?.[date.getDay()] ?? '星期日';
    return `${formatDateTime(date)} ${weekday}`;
};

