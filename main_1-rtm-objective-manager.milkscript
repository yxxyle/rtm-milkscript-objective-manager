    LATE_THRESHOLD: 21      // 熔断阈值：超过21点，今天不再算作有效加班日
};

/**
 * 安全获取全局比率
 * 融合了上游计算时的 Fallback 标记和本地的类型检查
 * 
 * @param {Object} objContext - 目标汇总信息 (来自 buildObjectivesContext)
 * @returns {{value: number, isFallback: boolean}}
 */
const getSafeGlobalRatio = (objContext) => {
    const rawRatio = objContext?.globalWorkRatio;
    const isUpstreamFallback = objContext?.globalWorkRatio_fallback === true;
    const isValidNumber = typeof rawRatio === 'number' && rawRatio > 0.1;

    return {
        value: isValidNumber ? rawRatio : 1.0,

        isFallback: isUpstreamFallback || !isValidNumber
    };
};

